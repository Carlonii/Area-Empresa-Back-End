{
  "title": "API Endpoints for Frontend",
  "base_url": "http://<HOST>:<PORT>",
  "auth": {
    "user_login": {
      "path": "/auth/login",
      "method": "POST",
      "content_type": "application/x-www-form-urlencoded",
      "description": "OAuth2 password flow for application users (form fields: username, password)",
      "response_example": { "access_token": "<jwt>", "token_type": "bearer" }
    },
    "employee_login": {
      "path": "/login",
      "method": "POST",
      "content_type": "application/json",
      "description": "Employee login (JSON body)",
      "request_example": { "email": "func@ex.com", "password": "senha123" },
      "response_example": { "access_token": "<jwt>", "token_type": "bearer" }
    },
    "header": "Authorization: Bearer <JWT>"
  },
  "endpoints": [
    {
      "group": "Companies",
      "items": [
        {
          "path": "/companies/",
          "method": "POST",
          "auth_required": false,
          "content_type": "application/json",
          "request_example": { "name": "Empresa X", "cnpj": "00.000.000/0000-00", "wallet_address": "0xabc..." },
          "response_example": { "id": "<uuid>", "name": "Empresa X", "cnpj": "00...", "wallet_address": "0xabc...", "created_at": "2025-11-17T12:00:00Z" },
          "notes": "Creates a new company. `wallet_address` must be unique."
        },
        {
          "path": "/companies/",
          "method": "GET",
          "auth_required": false,
          "response_example": [ { "id": "<uuid>", "name": "Empresa X", "cnpj": null, "wallet_address": "0xabc...", "created_at": "2025-11-17T12:00:00Z" } ],
          "notes": "List all companies. Returns array of CompanyPublic." 
        }
      ]
    },
    {
      "group": "Employees",
      "items": [
        {
          "path": "/companies/{company_id}/employees/",
          "method": "POST",
          "auth_required": false,
          "content_type": "application/json",
          "request_example": { "company_id": "<company-uuid>", "name": "Fulano", "email": "f@ex.com", "password": "senha123", "role": "admin" },
          "response_example": { "id": "<uuid>", "company_id": "<company-uuid>", "name": "Fulano", "email": "f@ex.com", "role": "admin", "created_at": "2025-11-17T12:00:00Z" },
          "notes": "Creates an employee for the company. If `company_id` path differs, API will set company_id to the path value."
        },
        {
          "path": "/companies/{company_id}/employees/",
          "method": "GET",
          "auth_required": true,
          "auth_role_required": "admin",
          "content_type": "application/json",
          "response_example": [ { "id": "<uuid>", "company_id": "<company-uuid>", "name": "Fulano", "email": "f@ex.com", "role": "admin", "created_at": "2025-11-17T12:00:00Z" } ],
          "notes": "Only admin employees of the company can list employees. Provide employee JWT in Authorization header."
        },
        {
          "path": "/companies/{company_id}/employees/{employee_id}",
          "method": "GET",
          "auth_required": true,
          "content_type": "application/json",
          "response_example": { "id": "<uuid>", "company_id": "<company-uuid>", "name": "Fulano", "email": "f@ex.com", "role": "admin", "created_at": "2025-11-17T12:00:00Z" },
          "notes": "Authenticated employees can get employee details if they belong to same company or are authorized."
        },
        {
          "path": "/companies/{company_id}/employees/{employee_id}",
          "method": "PUT",
          "auth_required": true,
          "content_type": "application/json",
          "request_example": { "name": "Novo Nome" },
          "response_example": { "id": "<uuid>", "company_id": "<company-uuid>", "name": "Novo Nome", "email": "f@ex.com", "role": "admin", "created_at": "2025-11-17T12:00:00Z" },
          "notes": "Only admin or the employee itself can update. To change password send `{ \"password\": \"novaSenha\" }` (API will hash it)."
        },
        {
          "path": "/companies/{company_id}/employees/{employee_id}",
          "method": "DELETE",
          "auth_required": true,
          "auth_role_required": "admin",
          "content_type": "application/json",
          "response_example": { "id": "<uuid>", "company_id": "<company-uuid>", "name": "Fulano", "email": "f@ex.com", "role": "admin", "created_at": "2025-11-17T12:00:00Z" },
          "notes": "Only admin of the company can delete an employee. Returns the deleted employee object." 
        }
      ]
    },
    {
      "group": "Roles",
      "items": [
        {
          "path": "/roles/",
          "method": "POST",
          "auth_required": true,
          "auth_role_required": "admin",
          "content_type": "application/json",
          "request_example": { "name": "manager" },
          "response_example": { "id": 1, "name": "manager" }
        },
        {
          "path": "/roles/",
          "method": "GET",
          "auth_required": true,
          "auth_role_required": "admin",
          "response_example": [ { "id": 1, "name": "manager" } ]
        },
        {
          "path": "/roles/{role_id}",
          "method": "GET",
          "auth_required": true,
          "auth_role_required": "admin",
          "response_example": { "id": 1, "name": "manager" }
        },
        {
          "path": "/roles/{role_id}",
          "method": "PUT",
          "auth_required": true,
          "auth_role_required": "admin",
          "content_type": "application/json",
          "request_example": { "name": "novoNome" },
          "response_example": { "id": 1, "name": "novoNome" }
        },
        {
          "path": "/roles/{role_id}",
          "method": "DELETE",
          "auth_required": true,
          "auth_role_required": "admin",
          "response_example": { "id": 1, "name": "manager" }
        }
      ]
    },
    {
      "group": "Users",
      "items": [
        {
          "path": "/users/",
          "method": "POST",
          "auth_required": true,
          "content_type": "application/json",
          "request_example": {
            "email": "user@ex.com",
            "password": "senha123",
            "full_name": "Nome Completo",
            "profile_image_url": "https://...",
            "profile_image_base64": null,
            "role_id": 2
          },
          "response_example": {
            "id": 12,
            "email": "user@ex.com",
            "full_name": "Nome Completo",
            "profile_image_url": "https://...",
            "profile_image_base64": null,
            "role": { "id": 2, "name": "roleName" }
          }
        },
        {
          "path": "/users/",
          "method": "GET",
          "auth_required": true,
          "response_example": [ { "id": 12, "email": "user@ex.com", "full_name": "Nome", "profile_image_url": null, "profile_image_base64": null, "role": { "id": 2, "name": "roleName" } } ]
        },
        {
          "path": "/users/{user_id}",
          "method": "GET",
          "auth_required": true,
          "response_example": { "id": 12, "email": "user@ex.com", "full_name": "Nome", "profile_image_url": null, "profile_image_base64": null, "role": { "id": 2, "name": "roleName" } }
        },
        {
          "path": "/users/{user_id}",
          "method": "PUT",
          "auth_required": true,
          "content_type": "application/json",
          "request_example": { "full_name": "Novo Nome", "profile_image_url": "https://..." },
          "response_example": { "id": 12, "email": "user@ex.com", "full_name": "Novo Nome", "profile_image_url": "https://...", "profile_image_base64": null, "role": { "id": 2, "name": "roleName" } }
        },
        {
          "path": "/users/{user_id}",
          "method": "DELETE",
          "auth_required": true,
          "response_example": { "id": 12, "email": "user@ex.com", "full_name": "Nome", "profile_image_url": null, "profile_image_base64": null, "role": { "id": 2, "name": "roleName" } }
        }
      ]
    },
    {
      "group": "Data",
      "items": [
        {
          "path": "/data/check-consent",
          "method": "POST",
          "auth_required": true,
          "content_type": "application/json",
          "request_example": { "customer_wallet": "0xabc..." },
          "response_examples": {
            "authorized": { "status": "AUTHORIZED", "cid": "<cid-or-null>" },
            "denied": { "status": "DENIED" }
          },
          "error_responses": {
            "503": "{ \"detail\": \"Blockchain provider not available\" }",
            "500": "{ \"detail\": \"<error message>\" }",
            "400": "{ \"detail\": \"Employee has no company\" }"
          },
          "notes": "Checks consent status calling a smart contract. Requires environment variables: DATA_CONSENT_ADDRESS, DATA_CONSENT_ABI_PATH (optional)."
        }
      ]
    },
    {
      "group": "Audit",
      "items": [
        {
          "path": "/audit/logs",
          "method": "GET",
          "auth_required": true,
          "content_type": "application/json",
          "response_example": [
            {
              "id": "<uuid>",
              "employee_id": "<uuid|null>",
              "company_id": "<uuid|null>",
              "customer_wallet": "0xabc...",
              "action_type": "VERIFICAR_CONSENTIMENTO",
              "result": "AUTHORIZED",
              "timestamp": "2025-11-17T12:00:00Z"
            }
          ],
          "notes": "Returns audit logs for the authenticated employee's company."
        }
      ]
    }
  ],
  "common_notes": {
    "errors_format": "FastAPI default: { \"detail\": \"message\" }",
    "id_types": {
      "company_id": "UUID string",
      "employee_id": "UUID string",
      "user_id": "integer",
      "role_id": "integer"
    },
    "time_format": "ISO 8601 strings",
    "content_types": "JSON endpoints expect `application/json` unless noted otherwise"
  }
}
